# Используем официальный образ Python как базовый
FROM python:3.11-slim

# Устанавливаем рабочую директорию в контейнере
WORKDIR /app

# Копируем файл зависимостей backend
# ИЗМЕНЕНИЕ: Убираем "backend/" из пути
COPY requirements.txt .

# Устанавливаем зависимости backend
RUN pip install --no-cache-dir -r requirements.txt

# Копируем код приложения backend
# ИЗМЕНЕНИЕ: Убираем "backend/" из пути
COPY main.py .
# Копируем файл данных. Он будет смонтирован как volume для персистентности.
# Эта копия нужна для создания образа, если файл существует.
# ИЗМЕНЕНИЕ: Убираем "backend/" из пути
COPY data.csv .

# Открываем порт, на котором будет работать FastAPI (8888, как указано в задании)
EXPOSE 8888

# Команда для запуска uvicorn при старте контейнера
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8888"]